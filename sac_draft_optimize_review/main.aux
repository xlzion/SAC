\@writefile{toc}{\contentsline {subsection}{\numberline {6.1}Qwen27B Provides the Cleanest Frontier Shift}{12}{subsection.6.1}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {6.2}Qwen4B Has a Steeper but Non-Degenerate Frontier}{12}{subsection.6.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Cross-model \textsc  {SAC}{} frontier geometry. Each panel reports the same quantities but uses a panel-specific zoom so local structure is visible: x reports TH ASR removed relative to the backdoored adapter, and y reports triggered-benign refusal; both axes are shown as percentages, while the tables report the same rates on a 0--1 scale. Point labels identify either the SAC gate budget, materialization operator, or additional configuration. (a) Qwen27B zooms into the selected endpoint to separate the gate-only and gate-plus-INT8 variants. (b) Qwen4B shows a steeper but non-degenerate small-model frontier, including rank-64 and target-all-linear points. (c) Gemma forms a low-TB operator band. (d) Llama shows a higher-cost curve where stronger safety movement coincides with utility cost, indicated by marker fill.}}{13}{figure.caption.18}\protected@file@percent }
\newlabel{fig:cross_model_frontiers}{{5}{13}{Cross-model \sac {} frontier geometry. Each panel reports the same quantities but uses a panel-specific zoom so local structure is visible: x reports TH ASR removed relative to the backdoored adapter, and y reports triggered-benign refusal; both axes are shown as percentages, while the tables report the same rates on a 0--1 scale. Point labels identify either the SAC gate budget, materialization operator, or additional configuration. (a) Qwen27B zooms into the selected endpoint to separate the gate-only and gate-plus-INT8 variants. (b) Qwen4B shows a steeper but non-degenerate small-model frontier, including rank-64 and target-all-linear points. (c) Gemma forms a low-TB operator band. (d) Llama shows a higher-cost curve where stronger safety movement coincides with utility cost, indicated by marker fill}{figure.caption.18}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.3}Gemma Shows a Cross-Family Improvement}{13}{subsection.6.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Qwen27B mechanism evidence from gate analysis. (a) The top 20\% of the \textsc  {SAC}{} alpha ranking is concentrated across specific layer/projection cells; each number is the count of dropped ranks out of 32. (b) The teal curve is the \textsc  {SAC}{} alpha-budget sweep along one ranking, with TH ASR shown as a percentage; the figure label ``SAC 80\%'' denotes the selected \texttt  {SAC-alpha-80} endpoint, while the red point is ten-seed random pruning at the same 80\% budget. (c) Probe-size gates remain close to the selected \texttt  {SAC-alpha-80} gate; the dashed line marks the mean overlap with random 80\% gates, and Jaccard overlap remains on a 0--1 scale. Taken together, the panels indicate a stable, localized subset of adapter directions whose removal tracks TH suppression.}}{14}{figure.caption.19}\protected@file@percent }
\newlabel{fig:mechanism}{{6}{14}{Qwen27B mechanism evidence from gate analysis. (a) The top 20\% of the \sac {} alpha ranking is concentrated across specific layer/projection cells; each number is the count of dropped ranks out of 32. (b) The teal curve is the \sac {} alpha-budget sweep along one ranking, with TH ASR shown as a percentage; the figure label ``SAC 80\%'' denotes the selected \method {SAC-alpha-80} endpoint, while the red point is ten-seed random pruning at the same 80\% budget. (c) Probe-size gates remain close to the selected \method {SAC-alpha-80} gate; the dashed line marks the mean overlap with random 80\% gates, and Jaccard overlap remains on a 0--1 scale. Taken together, the panels indicate a stable, localized subset of adapter directions whose removal tracks TH suppression}{figure.caption.19}{}}
