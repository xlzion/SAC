\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Primary Qwen27B safety-utility evidence. \textsc  {SAC}{} changes the behavior under the same compression budget: uniform quantization preserves the attack, random pruning only partially suppresses it, and the selected gate substantially reduces TH ASR while retaining MMLU and low TB refusal. ASR and refusal rates are shown as percentages in the figure; MMLU remains on its standard 0--1 scale.}}{10}{figure.caption.12}\protected@file@percent }
\newlabel{fig:frontier_map}{{2}{10}{Primary Qwen27B safety-utility evidence. \sac {} changes the behavior under the same compression budget: uniform quantization preserves the attack, random pruning only partially suppresses it, and the selected gate substantially reduces TH ASR while retaining MMLU and low TB refusal. ASR and refusal rates are shown as percentages in the figure; MMLU remains on its standard 0--1 scale}{figure.caption.12}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces External transfer on Qwen27B. The selected \textsc  {SAC}{} adapter reduces ASR across AdvBench and HarmBench variants; gray segments connect paired backdoor-reference and \textsc  {SAC}{} values within each benchmark. ASR labels are shown as percentages.}}{10}{figure.caption.15}\protected@file@percent }
\newlabel{fig:external_transfer}{{3}{10}{External transfer on Qwen27B. The selected \sac {} adapter reduces ASR across AdvBench and HarmBench variants; gray segments connect paired backdoor-reference and \sac {} values within each benchmark. ASR labels are shown as percentages}{figure.caption.15}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Compression and external-control rows. Similar-looking deployment operators can preserve the backdoor, while behavior-aware selection suppresses TH ASR; the clean-text FP8 row is shown only as a separate external control on the same percentage TH ASR axis, with full FP8 details deferred to Appendix~\ref {app:supp-results}.}}{10}{figure.caption.17}\protected@file@percent }
\newlabel{fig:operator_controls}{{4}{10}{Compression and external-control rows. Similar-looking deployment operators can preserve the backdoor, while behavior-aware selection suppresses TH ASR; the clean-text FP8 row is shown only as a separate external control on the same percentage TH ASR axis, with full FP8 details deferred to Appendix~\ref {app:supp-results}}{figure.caption.17}{}}
